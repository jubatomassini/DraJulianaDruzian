# URL canônica do site (sem barra final). Ex.: https://www.drajulianadruzian.com.br
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp em formato E.164, só dígitos com DDI 55. Ex.: 556635310333
NEXT_PUBLIC_WHATSAPP_E164=556635310333

# Dados do consultório (SEO local + rodapé)
NEXT_PUBLIC_CITY_UF=Sinop – MT
NEXT_PUBLIC_ADDRESS=Clínica Cimed Sinop — Av. das Embaúbas, 1900 — CEP 78550-084
NEXT_PUBLIC_CRM=RQE 9656

# Google Maps: URL do iframe (embed) e link "Como chegar"
NEXT_PUBLIC_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3918.5!2d-55.5100817!3d-11.8568691!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x93a77f53ff4310bb%3A0x4d06e7bf295c4689!2sCl%C3%ADnica%20Cimed!5e0!3m2!1spt-BR!2sbr!4v1!5m2!1spt-BR!2sbr
NEXT_PUBLIC_MAPS_DIRECTIONS_URL=https://maps.app.goo.gl/V5DLQ9kPJwKnQvZr6

# Hero: padrão é /dra-juliana-druzian-reumatologista-nova.webp em /public
# Defina outro caminho só se quiser trocar a imagem.
NEXT_PUBLIC_HERO_IMAGE=
# Sobre: padrão é /dra-juliana-druzian.jpg em /public
NEXT_PUBLIC_ABOUT_IMAGE=

# true em produção com endereço real (JSON-LD com endereço)
NEXT_PUBLIC_JSONLD_INCLUDE_ADDRESS=true

# Redes e currículo (menu do site — deixe vazio para ocultar o ícone)
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LATTES_URL=
