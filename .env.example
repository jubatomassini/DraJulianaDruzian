# URL canônica do site (sem barra final). Ex.: https://www.drajulianadruzian.com.br
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp em formato E.164, só dígitos com DDI 55. Ex.: 5567991234567
NEXT_PUBLIC_WHATSAPP_E164=

# Dados do consultório (SEO local + rodapé)
NEXT_PUBLIC_CITY_UF=Campo Grande – MS
NEXT_PUBLIC_ADDRESS=Rua Exemplo, 123 — Bairro — CEP
NEXT_PUBLIC_CRM=CRM-MS 12345

# Google Maps: URL do iframe (embed) e link "Como chegar"
NEXT_PUBLIC_MAPS_EMBED_URL=
NEXT_PUBLIC_MAPS_DIRECTIONS_URL=

# Fotos em /public (opcional). Ex.: /images/hero.jpg
NEXT_PUBLIC_HERO_IMAGE=
NEXT_PUBLIC_ABOUT_IMAGE=

# Só true em produção com endereço real verificado (JSON-LD com endereço)
NEXT_PUBLIC_JSONLD_INCLUDE_ADDRESS=false

# Redes e currículo (menu do site — deixe vazio para ocultar o ícone)
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LATTES_URL=
